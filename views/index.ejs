<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="/stylesheets/style.css" />
    <link rel="stylesheet" href="/stylesheets/dashboard.css" />
  </head>
  <body class="d-flex">

    <!-- Sidebar -->
    <aside class="sidebar">
      <div class="brand">
        <i class="bi bi-ticket-perforated me-2"></i>CRM
      </div>

      <nav class="nav flex-column pt-2">
        <a href="/" class="nav-link active">
          <i class="bi bi-house-door"></i> Home
        </a>
      </nav>

      <!-- User info + logout pinned to bottom -->
      <div class="sidebar-footer">
        <div class="d-flex align-items-center justify-content-between">
          <div>
            <div class="username"><%= user.username %></div>
            <div class="user-role">Logged in</div>
          </div>
          <a href="/logout" class="btn btn-sm btn-outline-light" title="Logout">
            <i class="bi bi-box-arrow-right"></i>
          </a>
        </div>
      </div>
    </aside>

    <!-- Main content -->
    <main class="main-content p-4">
      <h5 class="mb-4 fw-semibold">Home</h5>

      <div class="row g-3 mb-4">
        <div class="col-sm-6 col-lg-4">
          <div class="card stat-card p-3">
            <div class="text-muted small mb-1">Logged in as</div>
            <div class="fw-semibold fs-5"><%= user.username %></div>
          </div>
        </div>
        <div class="col-sm-6 col-lg-4">
          <div class="card stat-card p-3">
            <div class="text-muted small mb-1">User ID</div>
            <div class="fw-semibold fs-5">#<%= user.id %></div>
          </div>
        </div>
        <div class="col-sm-6 col-lg-4">
          <div class="card stat-card p-3">
            <div class="text-muted small mb-1">Session</div>
            <div class="fw-semibold fs-5 text-success">Active</div>
          </div>
        </div>
      </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
