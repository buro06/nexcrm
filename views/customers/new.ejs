<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %> – NexCRM</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="/stylesheets/style.css" />
    <link rel="stylesheet" href="/stylesheets/dashboard.css" />
  </head>
  <body class="d-flex">

    <%- include('../partials/sidebar', { active: 'customers' }) %>

    <main class="main-content p-4">
      <div class="d-flex align-items-center mb-4">
        <a href="/customers" class="btn-logout me-3" title="Back">
          <i class="bi bi-arrow-left"></i>
        </a>
        <h5 class="fw-semibold mb-0">Add Customer</h5>
      </div>

      <div class="card stat-card p-4" style="max-width: 560px;">
        <% if (errors.length > 0) { %>
          <div class="alert alert-danger py-2">
            <% errors.forEach(function(e) { %><div><%= e %></div><% }); %>
          </div>
        <% } %>

        <form method="POST" action="/customers">
          <div class="mb-3">
            <label for="name" class="form-label">Name <span class="text-danger">*</span></label>
            <input type="text" class="form-control" id="name" name="name"
                   value="<%= typeof values !== 'undefined' ? values.name || '' : '' %>" required />
          </div>
          <div class="mb-3">
            <label for="email" class="form-label">Email</label>
            <input type="email" class="form-control" id="email" name="email"
                   value="<%= typeof values !== 'undefined' ? values.email || '' : '' %>" />
          </div>
          <div class="mb-3">
            <label for="phone" class="form-label">Phone</label>
            <input type="tel" class="form-control" id="phone" name="phone"
                   value="<%= typeof values !== 'undefined' ? values.phone || '' : '' %>"
                   placeholder="555-123-4567" maxlength="12" />
          </div>

          <hr class="my-3" />
          <div class="mb-2 text-muted small fw-semibold text-uppercase" style="letter-spacing:.05em;">Address</div>

          <div class="mb-3">
            <label for="street" class="form-label">Street</label>
            <div>
              <input type="text" class="form-control" id="street" name="street"
                     value="<%= typeof values !== 'undefined' ? values.street || '' : '' %>"
                     placeholder="Start typing to search…" autocomplete="off" />
            </div>
          </div>
          <div class="row g-2 mb-3">
            <div class="col-sm-5">
              <label for="city" class="form-label">City</label>
              <input type="text" class="form-control" id="city" name="city"
                     value="<%= typeof values !== 'undefined' ? values.city || '' : '' %>" />
            </div>
            <div class="col-sm-4">
              <label for="state" class="form-label">State</label>
              <input type="text" class="form-control" id="state" name="state"
                     value="<%= typeof values !== 'undefined' ? values.state || '' : '' %>" />
            </div>
            <div class="col-sm-3">
              <label for="zip" class="form-label">Zip</label>
              <input type="text" class="form-control" id="zip" name="zip"
                     value="<%= typeof values !== 'undefined' ? values.zip || '' : '' %>"
                     maxlength="10" />
            </div>
          </div>

          <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-primary">Save Customer</button>
            <a href="/customers" class="btn btn-outline-secondary">Cancel</a>
          </div>
        </form>
      </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/javascripts/phone-format.js"></script>
    <script src="/javascripts/address-autocomplete.js"></script>
  </body>
</html>
