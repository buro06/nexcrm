<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= customer.name %> – NexCRM</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="/stylesheets/style.css" />
    <link rel="stylesheet" href="/stylesheets/dashboard.css" />
  </head>
  <body class="d-flex">
    <%- include('../partials/sidebar', { active: 'customers' }) %>
    <main class="main-content p-4">

      <div class="d-flex align-items-center mb-4">
        <a href="/customers" class="btn-logout me-3" title="Back"><i class="bi bi-arrow-left"></i></a>
        <h5 class="fw-semibold mb-0"><%= customer.name %></h5>
        <div class="ms-auto d-flex gap-2">
          <a href="/assets/new?customer_id=<%= customer.id %>" class="btn btn-primary btn-sm">
            <i class="bi bi-laptop me-1"></i> Add Asset
          </a>
          <a href="/customers/<%= customer.id %>/edit" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-pencil me-1"></i> Edit
          </a>
        </div>
      </div>

      <div class="row g-3 mb-4">
        <div class="col-sm-6 col-lg-3">
          <div class="card stat-card p-3">
            <div class="text-muted small mb-1">Email</div>
            <div class="fw-medium"><%= customer.email || '—' %></div>
          </div>
        </div>
        <div class="col-sm-6 col-lg-3">
          <div class="card stat-card p-3">
            <div class="text-muted small mb-1">Phone</div>
            <div class="fw-medium"><%= customer.phone || '—' %></div>
          </div>
        </div>
        <div class="col-sm-6 col-lg-3">
          <div class="card stat-card p-3">
            <div class="text-muted small mb-1">City / State</div>
            <div class="fw-medium"><%= [customer.city, customer.state].filter(Boolean).join(', ') || '—' %></div>
          </div>
        </div>
        <div class="col-sm-6 col-lg-3">
          <div class="card stat-card p-3">
            <div class="text-muted small mb-1">Street / Zip</div>
            <div class="fw-medium"><%= customer.street || '—' %><% if (customer.zip) { %>, <%= customer.zip %><% } %></div>
          </div>
        </div>
      </div>

      <h6 class="fw-semibold mb-3">Assets</h6>

      <% if (assets.length === 0) { %>
        <div class="card stat-card p-4 text-center text-muted">
          <i class="bi bi-laptop fs-2 mb-2"></i>
          <div>No assets assigned. <a href="/assets/new?customer_id=<%= customer.id %>">Add one.</a></div>
        </div>
      <% } else { %>
        <div class="card stat-card">
          <div class="table-responsive">
            <table class="table table-hover mb-0">
              <thead class="table-light">
                <tr>
                  <th>Tag #</th>
                  <th>Display Name</th>
                  <th>Make</th>
                  <th>Model #</th>
                  <th>Serial #</th>
                  <th></th>
                </tr>
              </thead>
              <tbody>
                <% assets.forEach(function(a) { %>
                  <tr>
                    <td><span class="badge bg-secondary fw-normal"><%= a.tag_number || '—' %></span></td>
                    <td class="fw-medium"><%= a.display_name %></td>
                    <td><%= a.make %></td>
                    <td><%= a.model_number %></td>
                    <td><%= a.serial_number || '—' %></td>
                    <td class="text-end" style="white-space:nowrap;">
                      <a href="/assets/<%= a.id %>/edit" class="btn btn-sm btn-outline-secondary me-1">
                        <i class="bi bi-pencil"></i>
                      </a>
                      <form method="POST" action="/assets/<%= a.id %>/delete" class="d-inline"
                            onsubmit="return confirm('Delete <%= a.display_name %>?')">
                        <button type="submit" class="btn btn-sm btn-outline-danger">
                          <i class="bi bi-trash"></i>
                        </button>
                      </form>
                    </td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        </div>
      <% } %>

    </main>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
