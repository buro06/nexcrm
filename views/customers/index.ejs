<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %> – NexCRM</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="/stylesheets/style.css" />
    <link rel="stylesheet" href="/stylesheets/dashboard.css" />
  </head>
  <body class="d-flex">

    <%- include('../partials/sidebar', { active: 'customers' }) %>

    <main class="main-content p-4">

      <!-- Header -->
      <div class="d-flex align-items-center justify-content-between mb-3">
        <h5 class="fw-semibold mb-0">Customers</h5>
        <a href="/customers/new" class="btn btn-primary btn-sm">
          <i class="bi bi-plus-lg me-1"></i> Add Customer
        </a>
      </div>

      <!-- Search -->
      <form method="GET" action="/customers" class="mb-3">
        <div class="input-group">
          <span class="input-group-text bg-white border-end-0">
            <i class="bi bi-search text-muted"></i>
          </span>
          <input
            type="text"
            class="form-control border-start-0 ps-0"
            name="q"
            value="<%= q %>"
            placeholder="Search by name, email, phone or address…"
          />
          <% if (q) { %>
            <a href="/customers" class="btn btn-outline-secondary">Clear</a>
          <% } %>
        </div>
        <% if (q) { %>
          <div class="form-text mt-1">
            <%= total %> result<%= total !== 1 ? 's' : '' %> for "<%= q %>"
          </div>
        <% } %>
      </form>

      <!-- Table -->
      <% if (customers.length === 0) { %>
        <div class="card stat-card p-4 text-center text-muted">
          <i class="bi bi-people fs-2 mb-2"></i>
          <% if (q) { %>
            <div>No customers match "<%= q %>".</div>
          <% } else { %>
            <div>No customers yet. <a href="/customers/new">Add the first one.</a></div>
          <% } %>
        </div>
      <% } else { %>
        <div class="card stat-card mb-3">
          <div class="table-responsive">
            <table class="table table-hover mb-0">
              <thead class="table-light">
                <tr>
                  <th>Name</th>
                  <th>Email</th>
                  <th>Phone</th>
                  <th>Address</th>
                  <th></th>
                </tr>
              </thead>
              <tbody>
                <% customers.forEach(function(c) { %>
                  <tr>
                    <td class="fw-medium"><%= c.name %></td>
                    <td><%= c.email || '—' %></td>
                    <td><%= c.phone || '—' %></td>
                    <td><%= c.address || '—' %></td>
                    <td class="text-end" style="white-space: nowrap;">
                      <a href="/customers/<%= c.id %>/edit" class="btn btn-sm btn-outline-secondary me-1">
                        <i class="bi bi-pencil"></i>
                      </a>
                      <form method="POST" action="/customers/<%= c.id %>/delete" class="d-inline"
                            onsubmit="return confirm('Delete <%= c.name %>?')">
                        <button type="submit" class="btn btn-sm btn-outline-danger">
                          <i class="bi bi-trash"></i>
                        </button>
                      </form>
                    </td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        </div>

        <!-- Pagination -->
        <% if (totalPages > 1) { %>
          <nav aria-label="Customer pages">
            <ul class="pagination pagination-sm mb-0">
              <li class="page-item <%= page <= 1 ? 'disabled' : '' %>">
                <a class="page-link" href="/customers?page=<%= page - 1 %><%= q ? '&q=' + encodeURIComponent(q) : '' %>">
                  <i class="bi bi-chevron-left"></i>
                </a>
              </li>

              <% for (var p = 1; p <= totalPages; p++) { %>
                <li class="page-item <%= p === page ? 'active' : '' %>">
                  <a class="page-link" href="/customers?page=<%= p %><%= q ? '&q=' + encodeURIComponent(q) : '' %>">
                    <%= p %>
                  </a>
                </li>
              <% } %>

              <li class="page-item <%= page >= totalPages ? 'disabled' : '' %>">
                <a class="page-link" href="/customers?page=<%= page + 1 %><%= q ? '&q=' + encodeURIComponent(q) : '' %>">
                  <i class="bi bi-chevron-right"></i>
                </a>
              </li>
            </ul>
          </nav>
        <% } %>
      <% } %>

    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
