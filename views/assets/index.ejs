<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %> – NexCRM</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="/stylesheets/style.css" />
    <link rel="stylesheet" href="/stylesheets/dashboard.css" />
  </head>
  <body class="d-flex">
    <%- include('../partials/sidebar', { active: 'assets' }) %>
    <main class="main-content p-4">

      <div class="d-flex align-items-center justify-content-between mb-3">
        <h5 class="fw-semibold mb-0">Assets</h5>
        <a href="/assets/new" class="btn btn-primary btn-sm">
          <i class="bi bi-plus-lg me-1"></i> Add Asset
        </a>
      </div>

      <form method="GET" action="/assets" class="mb-3">
        <div class="input-group">
          <span class="input-group-text bg-white border-end-0">
            <i class="bi bi-search text-muted"></i>
          </span>
          <input type="text" class="form-control border-start-0 ps-0" name="q" value="<%= q %>"
                 placeholder="Search by tag, name, make, model, serial…" />
          <% if (q) { %><a href="/assets" class="btn btn-outline-secondary">Clear</a><% } %>
        </div>
        <% if (q) { %>
          <div class="form-text mt-1"><%= total %> result<%= total !== 1 ? 's' : '' %> for "<%= q %>"</div>
        <% } %>
      </form>

      <% if (assets.length === 0) { %>
        <div class="card stat-card p-4 text-center text-muted">
          <i class="bi bi-laptop fs-2 mb-2"></i>
          <% if (q) { %>
            <div>No assets match "<%= q %>".</div>
          <% } else { %>
            <div>No assets yet. <a href="/assets/new">Add the first one.</a></div>
          <% } %>
        </div>
      <% } else { %>
        <div class="card stat-card mb-3">
          <div class="table-responsive">
            <table class="table table-hover mb-0">
              <thead class="table-light">
                <tr>
                  <th>Tag #</th>
                  <th>Display Name</th>
                  <th>Make</th>
                  <th>Model #</th>
                  <th>Serial #</th>
                  <th></th>
                </tr>
              </thead>
              <tbody>
                <% assets.forEach(function(a) { %>
                  <tr>
                    <td><span class="badge bg-secondary fw-normal"><%= a.tag_number || '—' %></span></td>
                    <td class="fw-medium"><%= a.display_name %></td>
                    <td><%= a.make %></td>
                    <td><%= a.model_number %></td>
                    <td><%= a.serial_number || '—' %></td>
                    <td class="text-end" style="white-space:nowrap;">
                      <a href="/assets/<%= a.id %>/edit" class="btn btn-sm btn-outline-secondary me-1">
                        <i class="bi bi-pencil"></i>
                      </a>
                      <form method="POST" action="/assets/<%= a.id %>/delete" class="d-inline"
                            onsubmit="return confirm('Delete <%= a.display_name %>?')">
                        <button type="submit" class="btn btn-sm btn-outline-danger">
                          <i class="bi bi-trash"></i>
                        </button>
                      </form>
                    </td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        </div>

        <% if (totalPages > 1) { %>
          <%
            var qs = q ? '&q=' + encodeURIComponent(q) : '';
            var pageLink = function(p) { return '/assets?page=' + p + qs; };
            var tokens = [];
            var WING = 2;
            for (var p = 1; p <= totalPages; p++) {
              if (p <= 1+WING+1 || p >= totalPages-WING-1 || Math.abs(p-page) <= WING) {
                tokens.push(p);
              } else if (tokens[tokens.length-1] !== 'ellipsis') {
                tokens.push('ellipsis');
              }
            }
          %>
          <div class="d-flex align-items-center gap-3">
            <nav><ul class="pagination pagination-sm mb-0">
              <li class="page-item <%= page<=1?'disabled':'' %>">
                <a class="page-link" href="<%= pageLink(page-1) %>"><i class="bi bi-chevron-left"></i></a>
              </li>
              <% tokens.forEach(function(t) { %>
                <% if (t==='ellipsis') { %>
                  <li class="page-item disabled"><span class="page-link">…</span></li>
                <% } else { %>
                  <li class="page-item <%= t===page?'active':'' %>">
                    <a class="page-link" href="<%= pageLink(t) %>"><%= t %></a>
                  </li>
                <% } %>
              <% }); %>
              <li class="page-item <%= page>=totalPages?'disabled':'' %>">
                <a class="page-link" href="<%= pageLink(page+1) %>"><i class="bi bi-chevron-right"></i></a>
              </li>
            </ul></nav>
            <span class="text-muted small">Page <%= page %> of <%= totalPages %></span>
          </div>
        <% } %>
      <% } %>

    </main>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
