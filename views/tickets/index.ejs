<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %> – NexCRM</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="/stylesheets/style.css" />
    <link rel="stylesheet" href="/stylesheets/dashboard.css" />
  </head>
  <body class="d-flex">
    <%- include('../partials/sidebar', { active: 'tickets' }) %>
    <main class="main-content p-4">

      <div class="d-flex align-items-center justify-content-between mb-3">
        <h5 class="fw-semibold mb-0">Tickets</h5>
        <a href="/tickets/new" class="btn btn-primary btn-sm">
          <i class="bi bi-plus-lg me-1"></i> New Ticket
        </a>
      </div>

      <form method="GET" action="/tickets" class="mb-3">
        <div class="d-flex gap-2">
          <div class="input-group">
            <span class="input-group-text bg-white border-end-0">
              <i class="bi bi-search text-muted"></i>
            </span>
            <input type="text" class="form-control border-start-0 ps-0" name="q" value="<%= q %>"
                   placeholder="Search by ticket #, issue, customer…" />
          </div>
          <select name="status" class="form-select" style="max-width:200px;" onchange="this.form.submit()">
            <option value="">Active Tickets</option>
            <% Object.entries(STATUS_LABELS).forEach(function([val, label]) { %>
              <option value="<%= val %>" <%= status === val ? 'selected' : '' %>><%= label %></option>
            <% }); %>
          </select>
          <% if (q || status) { %><a href="/tickets" class="btn btn-outline-secondary">Clear</a><% } %>
        </div>
        <% if (q || status) { %>
          <div class="form-text mt-1"><%= total %> result<%= total !== 1 ? 's' : '' %></div>
        <% } %>
      </form>

      <%
        var statusBadge = {
          open:            'primary',
          pending_payment: 'warning',
          waiting_pickup:  'info',
          part_request:    'secondary',
          complete:        'success',
        };
      %>

      <% if (tickets.length === 0) { %>
        <div class="card stat-card p-4 text-center text-muted">
          <i class="bi bi-ticket-perforated fs-2 mb-2"></i>
          <% if (q || status) { %>
            <div>No tickets match your filters.</div>
          <% } else { %>
            <div>No tickets yet. <a href="/tickets/new">Create the first one.</a></div>
          <% } %>
        </div>
      <% } else { %>
        <div class="card stat-card mb-3">
          <div class="table-responsive">
            <table class="table table-hover mb-0">
              <thead class="table-light">
                <tr>
                  <th>Ticket #</th>
                  <th>Customer</th>
                  <th>Asset</th>
                  <th>Issue</th>
                  <th>Status</th>
                  <th>Updated</th>
                  <th></th>
                </tr>
              </thead>
              <tbody>
                <% tickets.forEach(function(t) { %>
                  <tr style="cursor:pointer;" onclick="location.href='/tickets/<%= t.id %>'">
                    <td><span class="badge bg-secondary fw-normal"><%= t.ticket_number %></span></td>
                    <td class="fw-medium"><%= t.customer_name %></td>
                    <td>
                      <% if (t.asset_name) { %>
                        <span class="text-muted small"><%= t.asset_tag %></span>
                        <span class="d-block"><%= t.asset_name %></span>
                      <% } else { %>
                        <span class="text-muted">—</span>
                      <% } %>
                    </td>
                    <td style="max-width:260px;">
                      <div class="text-truncate"><%= t.issue %></div>
                    </td>
                    <td>
                      <span class="badge bg-<%= statusBadge[t.status] || 'secondary' %>">
                        <%= STATUS_LABELS[t.status] || t.status %>
                      </span>
                    </td>
                    <td class="text-muted small"><%= new Date(t.updated_at).toLocaleDateString() %></td>
                    <td class="text-end" style="white-space:nowrap;" onclick="event.stopPropagation()">
                      <a href="/tickets/<%= t.id %>/edit" class="btn btn-sm btn-outline-secondary me-1">
                        <i class="bi bi-pencil"></i>
                      </a>
                      <form method="POST" action="/tickets/<%= t.id %>/delete" class="d-inline"
                            onsubmit="return confirm('Delete ticket <%= t.ticket_number %>?')">
                        <button type="submit" class="btn btn-sm btn-outline-danger">
                          <i class="bi bi-trash"></i>
                        </button>
                      </form>
                    </td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        </div>

        <% if (totalPages > 1) { %>
          <%
            var qs = '';
            if (q)      qs += '&q='      + encodeURIComponent(q);
            if (status) qs += '&status=' + encodeURIComponent(status);
            var pageLink = function(p) { return '/tickets?page=' + p + qs; };
            var tokens = [];
            var WING = 2;
            for (var p = 1; p <= totalPages; p++) {
              if (p <= 1+WING+1 || p >= totalPages-WING-1 || Math.abs(p-page) <= WING) {
                tokens.push(p);
              } else if (tokens[tokens.length-1] !== 'ellipsis') {
                tokens.push('ellipsis');
              }
            }
          %>
          <div class="d-flex align-items-center gap-3">
            <nav><ul class="pagination pagination-sm mb-0">
              <li class="page-item <%= page<=1?'disabled':'' %>">
                <a class="page-link" href="<%= pageLink(page-1) %>"><i class="bi bi-chevron-left"></i></a>
              </li>
              <% tokens.forEach(function(t) { %>
                <% if (t==='ellipsis') { %>
                  <li class="page-item disabled"><span class="page-link">…</span></li>
                <% } else { %>
                  <li class="page-item <%= t===page?'active':'' %>">
                    <a class="page-link" href="<%= pageLink(t) %>"><%= t %></a>
                  </li>
                <% } %>
              <% }); %>
              <li class="page-item <%= page>=totalPages?'disabled':'' %>">
                <a class="page-link" href="<%= pageLink(page+1) %>"><i class="bi bi-chevron-right"></i></a>
              </li>
            </ul></nav>
            <span class="text-muted small">Page <%= page %> of <%= totalPages %></span>
          </div>
        <% } %>
      <% } %>

    </main>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
