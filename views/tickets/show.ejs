<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= ticket.ticket_number %> – NexCRM</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="/stylesheets/style.css" />
    <link rel="stylesheet" href="/stylesheets/dashboard.css" />
  </head>
  <body class="d-flex">
    <%- include('../partials/sidebar', { active: 'tickets' }) %>
    <main class="main-content p-4" style="max-width:860px;">

      <%
        var statusBadge = {
          open:            'primary',
          pending_payment: 'warning',
          waiting_pickup:  'info',
          part_request:    'secondary',
          complete:        'success',
        };
      %>

      <div class="d-flex align-items-center mb-4">
        <a href="/tickets" class="btn-logout me-3" title="Back"><i class="bi bi-arrow-left"></i></a>
        <div>
          <h5 class="fw-semibold mb-0"><%= ticket.ticket_number %></h5>
          <div class="text-muted small">Opened <%= new Date(ticket.created_at).toLocaleDateString('en-US', {month:'short', day:'numeric', year:'numeric'}) %></div>
        </div>
        <div class="ms-auto d-flex gap-2">
          <a href="/tickets/<%= ticket.id %>/edit" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-pencil me-1"></i> Edit
          </a>
          <form method="POST" action="/tickets/<%= ticket.id %>/delete" class="d-inline"
                onsubmit="return confirm('Delete ticket <%= ticket.ticket_number %>?')">
            <button type="submit" class="btn btn-outline-danger btn-sm">
              <i class="bi bi-trash me-1"></i> Delete
            </button>
          </form>
        </div>
      </div>

      <!-- Status strip -->
      <div class="card stat-card p-3 mb-3">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
          <div>
            <span class="text-muted small me-2">Status</span>
            <span class="badge bg-<%= statusBadge[ticket.status] || 'secondary' %> fs-6 px-3 py-2">
              <%= STATUS_LABELS[ticket.status] || ticket.status %>
            </span>
          </div>
          <form method="POST" action="/tickets/<%= ticket.id %>/status" class="d-flex gap-2 align-items-center">
            <select name="status" class="form-select form-select-sm" style="width:auto;">
              <% Object.entries(STATUS_LABELS).forEach(function([val, label]) { %>
                <option value="<%= val %>" <%= ticket.status === val ? 'selected' : '' %>><%= label %></option>
              <% }); %>
            </select>
            <button type="submit" class="btn btn-sm btn-primary">Update</button>
          </form>
        </div>
      </div>

      <!-- Customer / Asset -->
      <div class="row g-3 mb-3">
        <div class="col-sm-6">
          <div class="card stat-card p-3 h-100">
            <div class="text-muted small mb-1">Customer</div>
            <a href="/customers/<%= ticket.customer_id %>" class="fw-medium text-decoration-none">
              <%= ticket.customer_name %>
            </a>
          </div>
        </div>
        <div class="col-sm-6">
          <div class="card stat-card p-3 h-100">
            <div class="text-muted small mb-1">Asset</div>
            <% if (ticket.asset_name) { %>
              <div class="fw-medium"><%= ticket.asset_name %></div>
              <div class="text-muted small"><%= ticket.asset_tag %></div>
            <% } else { %>
              <div class="text-muted">No asset</div>
            <% } %>
          </div>
        </div>
      </div>

      <!-- Issue -->
      <div class="card stat-card p-4 mb-3">
        <h6 class="fw-semibold text-muted small text-uppercase mb-2">Issue</h6>
        <p class="mb-0" style="white-space:pre-wrap;"><%= ticket.issue %></p>
      </div>

      <!-- Solution -->
      <div class="card stat-card p-4 mb-3">
        <h6 class="fw-semibold text-muted small text-uppercase mb-2">Solution</h6>
        <% if (ticket.solution) { %>
          <p class="mb-0" style="white-space:pre-wrap;"><%= ticket.solution %></p>
        <% } else { %>
          <p class="text-muted mb-0">No solution recorded yet.</p>
        <% } %>
      </div>

      <!-- Notes -->
      <div class="card stat-card p-4">
        <h6 class="fw-semibold text-muted small text-uppercase mb-2">Notes</h6>
        <% if (ticket.notes) { %>
          <p class="mb-0" style="white-space:pre-wrap;"><%= ticket.notes %></p>
        <% } else { %>
          <p class="text-muted mb-0">No notes.</p>
        <% } %>
      </div>

    </main>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
