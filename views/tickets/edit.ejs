<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %> – NexCRM</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="/stylesheets/style.css" />
    <link rel="stylesheet" href="/stylesheets/dashboard.css" />
    <link href="https://cdn.jsdelivr.net/npm/tom-select@2.3.1/dist/css/tom-select.bootstrap5.min.css" rel="stylesheet" />
  </head>
  <body class="d-flex">
    <%- include('../partials/sidebar', { active: 'tickets' }) %>
    <main class="main-content p-4" style="max-width:760px;">

      <div class="d-flex align-items-center mb-4">
        <a href="/tickets/<%= ticket.id %>" class="btn-logout me-3" title="Back"><i class="bi bi-arrow-left"></i></a>
        <h5 class="fw-semibold mb-0">Edit <%= ticket.ticket_number %></h5>
      </div>

      <% if (errors.length) { %>
        <div class="alert alert-danger py-2">
          <% errors.forEach(function(e) { %><div><%= e %></div><% }); %>
        </div>
      <% } %>

      <form method="POST" action="/tickets/<%= ticket.id %>">

        <div class="card stat-card p-4 mb-3">
          <h6 class="fw-semibold mb-3">Customer & Asset</h6>

          <div class="mb-3">
            <label class="form-label fw-medium" for="customer_id">Customer <span class="text-danger">*</span></label>
            <select id="customer_id" name="customer_id" placeholder="Search customers…" required
                    data-options="<%= JSON.stringify(selectedCustomer ? [selectedCustomer] : []) %>"
                    data-items="<%= JSON.stringify(selectedCustomer ? [String(selectedCustomer.id)] : []) %>"></select>
          </div>

          <div class="mb-0">
            <label class="form-label fw-medium" for="asset_id">Asset <span class="text-muted fw-normal">(optional)</span></label>
            <select id="asset_id" name="asset_id" placeholder="Search assets…"
                    data-options="<%= JSON.stringify(selectedAsset ? [selectedAsset] : []) %>"
                    data-items="<%= JSON.stringify(selectedAsset ? [String(selectedAsset.id)] : []) %>"></select>
          </div>
        </div>

        <div class="card stat-card p-4 mb-3">
          <h6 class="fw-semibold mb-3">Ticket Details</h6>

          <div class="mb-3">
            <label class="form-label fw-medium" for="issue">Issue <span class="text-danger">*</span></label>
            <textarea class="form-control" id="issue" name="issue" rows="4" required><%= ticket.issue || '' %></textarea>
          </div>

          <div class="mb-3">
            <label class="form-label fw-medium" for="solution">Solution</label>
            <textarea class="form-control" id="solution" name="solution" rows="4"><%= ticket.solution || '' %></textarea>
          </div>

          <div class="mb-3">
            <label class="form-label fw-medium" for="notes">Notes</label>
            <textarea class="form-control" id="notes" name="notes" rows="3"><%= ticket.notes || '' %></textarea>
          </div>

          <div class="mb-0">
            <label class="form-label fw-medium" for="status">Status <span class="text-danger">*</span></label>
            <select class="form-select" id="status" name="status" required>
              <% Object.entries(STATUS_LABELS).forEach(function([val, label]) { %>
                <option value="<%= val %>" <%= ticket.status === val ? 'selected' : '' %>><%= label %></option>
              <% }); %>
            </select>
          </div>
        </div>

        <div class="d-flex gap-2">
          <button type="submit" class="btn btn-primary">Save Changes</button>
          <a href="/tickets/<%= ticket.id %>" class="btn btn-outline-secondary">Cancel</a>
        </div>
      </form>

    </main>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/tom-select@2.3.1/dist/js/tom-select.complete.min.js"></script>
    <script src="/javascripts/ticket-selects.js"></script>
  </body>
</html>
